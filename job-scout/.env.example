# OpenRouter — LLM API (used for scoring, research, level filtering)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Apify — LinkedIn job scraping
# Get your token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_your-token-here

# Notion — job database
# Create an integration at https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_your-token-here
NOTION_DATABASE_ID=your-database-id-here

# Discord — daily report notifications
# Create a webhook in your server: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here
